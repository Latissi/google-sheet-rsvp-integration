{
	"compilerOptions": {
		"target": "es2019",
		"module": "commonjs",
		"types": ["google-apps-script", "jest"],
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"rootDir": "src",
		"outDir": "dist",
		"declaration": false,
		"sourceMap": false,
		"noEmitOnError": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/__tests__/**", "node_modules", "dist"]
}
