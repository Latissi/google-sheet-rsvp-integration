@startuml
title Building Block View [Level 2] - Configuration Adapter

skinparam shadowing false
skinparam defaultTextAlignment center
skinparam package<<BlackBox>> {
  BackgroundColor black
  BorderColor black
  FontColor white
  FontSize 18
  Padding 60
}

package RSVP {
  package Services {
    interface IConfigurationProvider {
      + getPublicSheetId(): string
      + getTrainingSheetName(): string
      + getAttendanceConfig(): AttendanceConfig
      + getReminderDaysBeforeTraining(): number
      + getWebAppUrl(): string
    }

    interface IUserRepository {
      + getAllUsers(): UserRecord[]
      + getUserByMemberId(id: string): UserRecord | null
      + getUserByEmail(email: string): UserRecord | null
      + getUserByName(name: string): UserRecord | null
      + upsertUser(user: UserRecord): void
    }
  }

  package Infrastructure {
    package Adapters {
      component ConfigurationAdapter
    }

    package Gateway {
      interface ISheetGateway {
        + getSheetValues(sheetName: string): unknown[][]
        + setRowValues(sheetName: string, rowIndex: number, values: unknown[]): void
        + appendRow(sheetName: string, values: unknown[]): void
      }

      component GoogleSheetGateway
    }
    
    component Config {
        note "Returns process ENV,\nWEBAPPURL, etc.\nvia PropertiesService" as N1
    }
  }

  rectangle "Private Data Sheet" as PrivateSheet {
    database "Konfiguration\n(Tab)" as ConfigTab
    database "Benutzer\n(Tab)" as UserTab
  }
}

' Relations
ConfigurationAdapter .up.|> IConfigurationProvider
ConfigurationAdapter .up.|> IUserRepository

ConfigurationAdapter --> ISheetGateway : <<uses>>
GoogleSheetGateway .up.|> ISheetGateway

GoogleSheetGateway --> ConfigTab : <<reads/writes>>\n(SpreadsheetApp)
GoogleSheetGateway --> UserTab : <<reads/writes>>\n(SpreadsheetApp)

Config --> PropertiesService : <<calls>>
@enduml
