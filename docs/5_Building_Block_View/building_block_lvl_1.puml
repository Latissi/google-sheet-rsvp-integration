@startuml
title Building Block View [Level 1]

skinparam shadowing false
skinparam defaultTextAlignment center
skinparam rectangle {
  RoundCorner 12
}
skinparam package {
  RoundCorner 12
}
skinparam package<<BlackBox>> {
  BackgroundColor black
  BorderColor black
  FontColor white
  FontSize 18
  Padding 60
}
skinparam rectangle<<BlackBox>> {
  BackgroundColor black
  BorderColor black
  FontColor white
  FontSize 18
}

actor "Mitglied" as Member
actor "Trainer" as Trainer

rectangle "Public Training Sheet" as PublicSheet
rectangle "Private Data Sheet" as PrivateSheet

package RSVP {
  package "Application" as Application <<BlackBox>>
  package "Domain" as Domain <<BlackBox>>
  package "Infrastructure" as Infrastructure <<BlackBox>>
}

Member --> Application : Registrierung / RSVP
Trainer --> Application : Trainingsverwaltung
Application --> Member : Erinnerungen
Application --> Trainer : Teilnehmerliste

Application ..> Domain
Application ..> Infrastructure
Infrastructure ..> Domain

Infrastructure --> PublicSheet
Infrastructure --> PrivateSheet
@enduml
