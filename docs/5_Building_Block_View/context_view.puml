@startuml
title Building Block View [Level 1]

left to right direction
skinparam shadowing false
skinparam defaultTextAlignment center
skinparam rectangle {
  RoundCorner 12
}
skinparam package<<BlackBox>> {
  BackgroundColor black
  BorderColor black
  FontColor white
  FontSize 18
  Padding 60
}

actor "Mitglied" as Member
actor "Trainer" as Trainer
note right of Trainer : Trainer ist \nauch Mitglied

rectangle "Trainings Sheet" as Sheet

package RSVP {
  package TrainingSheetAccess <<BlackBox>>
  package Configuration <<BlackBox>>
  rectangle Formular
  package MailIssuer <<BlackBox>>
}

Member --> Formular : <<Formular>> Registrierung
Member -> MailIssuer : <<Mail Response>> Absage / Zusage
RSVP --> Member : <<Mail>> Erinnerung

RSVP --> Trainer: <<Mail>> Teilnehmerliste

Sheet -> TrainingSheetAccess : Lesen
TrainingSheetAccess -> Sheet : Schreiben

@enduml
