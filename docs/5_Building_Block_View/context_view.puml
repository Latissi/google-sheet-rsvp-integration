@startuml
title Context View

left to right direction
skinparam shadowing false
skinparam defaultTextAlignment center
skinparam rectangle {
  RoundCorner 12
}
skinparam package<<BlackBox>> {
  BackgroundColor black
  BorderColor black
  FontColor white
  FontSize 18
  Padding 60
}

actor "Mitglied" as Member
actor "Trainer" as Trainer

rectangle "Trainings Sheet" as Sheet

package "Training-RSVP-System\n\n\n\n" <<BlackBox>> as RSVP {
}

Member --> RSVP : Registrierung
Member -> RSVP : Absage / Zusage
RSVP --> Member : Erinnerung

Trainer --> RSVP : Registrierung
Trainer -> RSVP : Absage / Zusage
RSVP --> Trainer: Teilnehmerliste
RSVP --> Trainer : Erinnerung

Sheet -> RSVP 
RSVP -> Sheet

@enduml
