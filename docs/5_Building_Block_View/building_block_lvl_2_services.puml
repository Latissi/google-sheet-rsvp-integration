@startuml
title Building Block View [Level 2] - Services

skinparam shadowing false
skinparam defaultTextAlignment center
skinparam package<<BlackBox>> {
  BackgroundColor black
  BorderColor black
  FontColor white
  FontSize 18
  Padding 60
}

package RSVP {
  rectangle Formular
  package MailAdapter <<BlackBox>>
  package ResponseHandler <<BlackBox>>
  package TrainingSheetAdapter <<BlackBox>>
  package ConfigurationAdapter <<BlackBox>>

  package Services {
    ' Inbound Ports (Provided Interfaces for Driving Adapters)
    interface IRegistrationService
    interface IRsvpService
    interface INotificationService
    
    ' Outbound Ports (Required Interfaces for Driven Adapters)
    interface IMailProvider
    interface ITrainingDataRepository
    interface IConfigurationProvider

    ' Core Domain Components (Business Logic)
    component RegistrationManager
    component RsvpManager
    component NotificationManager

    ' Implementations of Provided Interfaces
    RegistrationManager -up-|> IRegistrationService
    RsvpManager -up-|> IRsvpService
    NotificationManager -up-|> INotificationService
    
    ' Internal dependencies on Required Interfaces
    RegistrationManager ..> ITrainingDataRepository
    RegistrationManager ..> IConfigurationProvider
    
    RsvpManager ..> ITrainingDataRepository
    RsvpManager ..> IConfigurationProvider
    RsvpManager ..> IMailProvider
    
    NotificationManager ..> ITrainingDataRepository
    NotificationManager ..> IConfigurationProvider
    NotificationManager ..> IMailProvider
  }
}

' Relationships from Adapters to Services Ports (Decoupled Dependencies)
Formular ..> IRegistrationService : <<uses>>
ResponseHandler ..> IRsvpService : <<uses>>
' Assuming a timer/trigger calls NotificationManager to send out emails
ResponseHandler ..> INotificationService : <<uses>>

' Driven Adapters implementing the core ports
TrainingSheetAdapter .up.|> ITrainingDataRepository : <<implements>>
ConfigurationAdapter .up.|> IConfigurationProvider : <<implements>>
MailAdapter .up.|> IMailProvider : <<implements>>

@enduml
